{
  "@context": {
    "@version": 1.1,
    "wiki": {
      "@id": "https://example.org/llm-wiki/",
      "@prefix": true
    },
    "source": {
      "@id": "https://example.org/llm-wiki/source/",
      "@prefix": true
    },
    "concept": {
      "@id": "https://example.org/llm-wiki/concept/",
      "@prefix": true
    },
    "entity": {
      "@id": "https://example.org/llm-wiki/entity/",
      "@prefix": true
    },
    "comparison": {
      "@id": "https://example.org/llm-wiki/comparison/",
      "@prefix": true
    },
    "synthesis": {
      "@id": "https://example.org/llm-wiki/synthesis/",
      "@prefix": true
    },
    "trace": {
      "@id": "https://example.org/llm-wiki/trace/",
      "@prefix": true
    },

    "rdf": {
      "@id": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
      "@prefix": true
    },
    "rdfs": {
      "@id": "http://www.w3.org/2000/01/rdf-schema#",
      "@prefix": true
    },
    "owl": {
      "@id": "http://www.w3.org/2002/07/owl#",
      "@prefix": true
    },
    "skos": {
      "@id": "http://www.w3.org/2004/02/skos/core#",
      "@prefix": true
    },
    "xsd": {
      "@id": "http://www.w3.org/2001/XMLSchema#",
      "@prefix": true
    },
    "sdo": {
      "@id": "https://schema.org/",
      "@prefix": true
    },
    "prov": {
      "@id": "http://www.w3.org/ns/prov#",
      "@prefix": true
    },

    "source_id": "@id",
    "concept_id": "@id",
    "entity_id": "@id",
    "comparison_id": "@id",
    "synthesis_id": "@id",
    "trace_id": "@id",

    "type": "wiki:pageType",
    "title": "rdfs:label",
    "aliases": {
      "@id": "skos:altLabel",
      "@container": "@set"
    },

    "related": {
      "@id": "wiki:related",
      "@type": "@id",
      "@container": "@set"
    },
    "derived_from": {
      "@id": "prov:wasDerivedFrom",
      "@type": "@id",
      "@container": "@set"
    },
    "about": {
      "@id": "sdo:about",
      "@type": "@id",
      "@container": "@set"
    },
    "mentions": {
      "@id": "sdo:mentions",
      "@type": "@id",
      "@container": "@set"
    },
    "implements": {
      "@id": "wiki:implements",
      "@type": "@id",
      "@container": "@set"
    },
    "depends_on": {
      "@id": "wiki:dependsOn",
      "@type": "@id",
      "@container": "@set"
    },
    "part_of": {
      "@id": "sdo:isPartOf",
      "@type": "@id",
      "@container": "@set"
    },

    "related_links": null,
    "derived_from_links": null,
    "about_links": null,
    "mentions_links": null,
    "implements_links": null,
    "depends_on_links": null,
    "part_of_links": null
  }
}
